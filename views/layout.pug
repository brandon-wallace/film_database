doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="/css/style.css")
        title #{title}
    body
        header
            nav
                input(type='checkbox')#hamburger__menu
                label(for='hamburger__menu')
                    span.hamburger__icon
                div.hamburger__overlay
                ul.menu
                    li.menu__item
                        a(href="/").menu__link home
                    li.menu__item
                        a(href="/login").menu__link login
                    li.menu__item
                        a(href="/signup").menu__link signup
                    li.menu__item
                        a(href="/films").menu__link films
                    li.menu__item
                        a(href="/addentry").menu__link addentry
        main
            block content
        footer

        script(src='../js/script.js')
